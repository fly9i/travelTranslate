# TravelTranslator 后端环境变量模板
# 复制为 .env 并填入真实值

# 应用配置
APP_NAME=TravelTranslator
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库（SQLite）
DATABASE_URL=sqlite+aiosqlite:///./data/traveltranslate.db

# 翻译引擎配置（可选，留空则使用内置词典）
# TRANSLATION_ENGINE: mock | anthropic
TRANSLATION_ENGINE=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# 日志等级
LOG_LEVEL=INFO
