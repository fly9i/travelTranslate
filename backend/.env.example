# TravelTranslator 后端环境变量模板
# 复制为 .env 并填入真实值

# 应用配置
APP_NAME=TravelTranslator
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库（SQLite）
DATABASE_URL=sqlite+aiosqlite:///./data/traveltranslate.db

# 翻译引擎配置（可选，留空则使用内置词典）
# TRANSLATION_ENGINE: mock | anthropic | openai（用于单条翻译 + polish）
TRANSLATION_ENGINE=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI 兼容接口（OPENAI_BASE_URL 可指向 DeepSeek / 通义 / Ollama / vLLM 等兼容服务）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 批量翻译引擎（/translate/batch 走这个，默认复用 TRANSLATION_ENGINE；
# 想走 Google Cloud Translation v3 时设为 google 并填 API Key）
# BATCH_TRANSLATION_ENGINE: inherit | google | anthropic | openai | mock
BATCH_TRANSLATION_ENGINE=inherit
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_TRANSLATE_BASE_URL=https://translation.googleapis.com

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# 日志等级
LOG_LEVEL=INFO
